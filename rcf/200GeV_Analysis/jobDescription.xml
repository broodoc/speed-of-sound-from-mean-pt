<?xml version="1.0" encoding="utf-8" ?>
<job simulateSubmission="false" maxFilesPerProcess="200" fileListSyntax="xrootd">
<command>
setenv NODEBUG yes
stardev
root4star -b -q -l 'runAnalysis.C(true, "_200p0_COL", "'$FILELIST'", "output.'${JOBID}'.root")'
</command>
<SandBox installer="ZIP">   
        <Package>
            <File>file:./runAnalysis.C</File>
            <File>file:./StRoot</File>  
            <File>file:./.sl73_gcc485</File>
        </Package>
</SandBox>

<stdout URL="file:./JobLogs/sched$JOBID.out"/>
<stderr URL="file:./JobLogs/sched$JOBID.err"/>

